# =============================================================================
# Unreal Engine 5 .gitignore
# =============================================================================

# Build artifacts and intermediate files (regenerated on build/open)
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

# Plugin build artifacts (only ignore inside Plugins/ subfolders)
Plugins/*/Binaries/
Plugins/*/Build/
Plugins/*/Intermediate/
Plugins/*/Saved/

# Visual Studio / Rider / VS Code project files (regenerated by UE)
.vs/
.vscode/
.idea/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.xcodeproj
*.xcworkspace

# Compiled outputs
*.o
*.obj
*.lib
*.a
*.so
*.dll
*.exe
*.app

# UE-generated module and target files
*.target
*.modules

# Crash dumps and logs
*.dmp
*.log

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Backup files
*.bak
*.tmp
*~

# NOTE: Do NOT ignore .uproject, .uplugin, Config/, Content/, Source/
# These are the actual project — they need to be committed.
